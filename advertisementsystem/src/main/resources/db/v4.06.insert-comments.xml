<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <changeSet id="insert-comments" author="developer">
        <comment>Insert initial comment data</comment>

        <insert tableName="comments">
            <column name="idbuyer" value="2"/>
            <column name="idadvertisement" value="1"/>
            <column name="comment" value="Отличная машина! Всё честно, рекомендую продавца"/>
            <column name="date" value="2024-03-20"/>
        </insert>

        <rollback>
            <delete tableName="comments">
                <where>idadvertisement=1</where>
            </delete>
        </rollback>
    </changeSet>

</databaseChangeLog>