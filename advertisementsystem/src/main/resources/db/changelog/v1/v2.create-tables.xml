<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <changeSet id="create-profile-table" author="developer">
        <comment>Create profile table</comment>
        <createTable tableName="profile">
            <column name="id" type="int" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="secondname" type="varchar(50)">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="varchar(50)">
                <constraints nullable="false"/>
            </column>
            <column name="fathername" type="varchar(50)">
                <constraints nullable="true"/>
            </column>
            <column name="address" type="varchar(250)">
                <constraints nullable="true"/>
            </column>
            <column name="number" type="int">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <rollback>
            <dropTable tableName="profile"/>
        </rollback>
    </changeSet>

    <changeSet id="create-user-table" author="developer">
        <comment>Create user table</comment>
        <createTable tableName="user">
            <column name="id" type="int" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="idprofile" type="int">
                <constraints nullable="false"
                             foreignKeyName="fk_user_profile"
                             references="profile(id)"/>
            </column>
            <column name="login" type="varchar(150)">
                <constraints nullable="false"/>
            </column>
            <column name="password" type="varchar(50)">
                <constraints nullable="false"/>
            </column>
            <column name="role" type="user_role">
                <constraints nullable="false"/>
            </column>
            <column name="enabled" type="boolean" defaultValueBoolean="true"/>
        </createTable>

        <rollback>
            <dropTable tableName="user"/>
        </rollback>
    </changeSet>

    <changeSet id="create-advertisement-table" author="developer">
        <comment>Create advertisement table</comment>
        <createTable tableName="advertisement">
            <column name="id" type="int" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="idseller" type="int">
                <constraints nullable="false"
                             foreignKeyName="fk_advertisement_seller"
                             references="user(id)"/>
            </column>
            <column name="title" type="varchar(250)">
                <constraints nullable="false"/>
            </column>
            <column name="category" type="product_category">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="varchar(350)">
                <constraints nullable="true"/>
            </column>
            <column name="publicationdate" type="date">
                <constraints nullable="false"/>
            </column>
            <column name="price" type="decimal(10,2)">
                <constraints nullable="false"/>
            </column>
            <column name="byestatus" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="advertisement_status">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <rollback>
            <dropTable tableName="advertisement"/>
        </rollback>
    </changeSet>

    <changeSet id="create-chat-table" author="developer">
        <comment>Create chat table</comment>
        <createTable tableName="chat">
            <column name="id" type="int" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="idseller" type="int">
                <constraints nullable="false"
                             foreignKeyName="fk_chat_seller"
                             references="user(id)"/>
            </column>
            <column name="idbuyer" type="int">
                <constraints nullable="false"
                             foreignKeyName="fk_chat_buyer"
                             references="user(id)"/>
            </column>
        </createTable>

        <rollback>
            <dropTable tableName="chat"/>
        </rollback>
    </changeSet>

    <changeSet id="create-comments-table" author="developer">
        <comment>Create comments table</comment>
        <createTable tableName="comments">
            <column name="id" type="int" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="idbuyer" type="int">
                <constraints nullable="false"
                             foreignKeyName="fk_comments_buyer"
                             references="user(id)"/>
            </column>
            <column name="idadvertisement" type="int">
                <constraints nullable="false"
                             foreignKeyName="fk_comments_advertisement"
                             references="advertisement(id)"/>
            </column>
            <column name="comment" type="varchar(350)">
                <constraints nullable="false"/>
            </column>
            <column name="date" type="date">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <rollback>
            <dropTable tableName="comments"/>
        </rollback>
    </changeSet>

    <changeSet id="create-message-table" author="developer">
        <comment>Create message table</comment>
        <createTable tableName="message">
            <column name="id" type="int" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="iduser" type="int">
                <constraints nullable="false"
                             foreignKeyName="fk_message_user"
                             references="user(id)"/>
            </column>
            <column name="idchat" type="int">
                <constraints nullable="false"
                             foreignKeyName="fk_message_chat"
                             references="chat(id)"/>
            </column>
            <column name="message" type="varchar(350)">
                <constraints nullable="false"/>
            </column>
            <column name="date" type="date">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <rollback>
            <dropTable tableName="message"/>
        </rollback>
    </changeSet>

    <changeSet id="create-score-table" author="developer">
        <comment>Create score table</comment>
        <createTable tableName="score">
            <column name="id" type="int" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="idseller" type="int">
                <constraints nullable="false"
                             foreignKeyName="fk_score_seller"
                             references="user(id)"/>
            </column>
            <column name="idbuyer" type="int">
                <constraints nullable="false"
                             foreignKeyName="fk_score_buyer"
                             references="user(id)"/>
            </column>
            <column name="idadvertisement" type="int">
                <constraints nullable="false"
                             foreignKeyName="fk_score_advertisement"
                             references="advertisement(id)"/>
            </column>
            <column name="score" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="comment" type="varchar(350)">
                <constraints nullable="false"/>
            </column>
            <column name="date" type="date">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <rollback>
            <dropTable tableName="score"/>
        </rollback>
    </changeSet>

</databaseChangeLog>