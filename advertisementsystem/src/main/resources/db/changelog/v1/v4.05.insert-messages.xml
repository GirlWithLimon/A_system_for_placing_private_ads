<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <changeSet id="insert-messages" author="developer">
        <comment>Insert initial message data</comment>

        <insert tableName="message">
            <column name="iduser" value="2"/>
            <column name="idchat" value="1"/>
            <column name="message" value="Здравствуйте! А у меня есть колеса)"/>
            <column name="date" value="2024-03-11"/>
        </insert>

        <insert tableName="message">
            <column name="iduser" value="1"/>
            <column name="idchat" value="1"/>
            <column name="message" value="Тогда могу сделать скидку)"/>
            <column name="date" value="2024-03-11"/>
        </insert>

        <rollback>
            <delete tableName="message">
                <where>idchat=1</where>
            </delete>
        </rollback>
    </changeSet>

</databaseChangeLog>